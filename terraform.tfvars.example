# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — do not commit it.

# ── Required ──────────────────────────────────────────────────────────────────

hcloud_token         = "your-hetzner-api-token-here"
ssh_public_key       = "ssh-ed25519 AAAA... your-key-here"
ssh_private_key_path = "~/.ssh/id_ed25519"

# ── VLESS users ───────────────────────────────────────────────────────────────
# Add/remove names and re-apply — no server rebuild needed.
# Names: alphanumeric, hyphens, underscores only.
vless_users = ["alice", "bob"]

# ── Grafana Cloud ─────────────────────────────────────────────────────────────
# Sign up free at https://grafana.com/auth/sign-up
# Then: Home → your stack → Prometheus → Details
grafana_cloud_prometheus_url  = "https://prometheus-xxx.grafana.net/api/prom/push"
grafana_cloud_prometheus_user = "123456"
# Generate API key: grafana.com → your org → Access Policies → MetricsPublisher role
grafana_cloud_api_key = "glc_eyJ..."

# Cloudflare API token for Let's Encrypt DNS-01 challenge (XHTTP TLS cert).
# Create at dash.cloudflare.com → My Profile → API Tokens
# Permissions needed: Zone:DNS:Edit for your vless_domain zone.
cloudflare_api_token = "your-cloudflare-api-token-here"

# ── Recommended ───────────────────────────────────────────────────────────────

# Restrict SSH to your own IP. Find it at https://ifconfig.me
# admin_cidr = ["203.0.113.1/32"]

# ── Optional overrides ────────────────────────────────────────────────────────

# location            = "nbg1"              # nbg1 fsn1 hel1 ash sin
# conduit_version     = "release-cli-2.0.0"
# conduit_bandwidth   = 40
# conduit_max_clients = 100
# conduit_cpu_quota   = "60%"
# xray_version        = "v26.4.25"
# xray_exporter_version = "v0.2.0"
# vless_sni           = "microsoft.com"
# vless_domain        = "example.com"        # domain for XHTTP TLS cert + XHTTP URI; A record must be DNS-only (unproxied)
# alloy_version       = "v1.8.3"

# ── Binary checksums (required) ───────────────────────────────────────────────
# Run: ./scripts/get-checksums.sh
# Paste the output here. Must be updated whenever any *_version changes above.
# Digests come from the GitHub Releases API (or each project's published checksum
# file where the API has none, e.g. Grafana SHA256SUMS). Recorded here, they are the pin.
conduit_sha256       = ""   # obtain via scripts/get-checksums.sh
xray_zip_sha256      = ""   # obtain via scripts/get-checksums.sh
alloy_zip_sha256     = ""   # obtain via scripts/get-checksums.sh
xray_exporter_sha256 = ""   # obtain via scripts/get-checksums.sh (no upstream checksums file — pinned here)
